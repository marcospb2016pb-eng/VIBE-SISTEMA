<!DOCTYPE html>
<html>
<head>
    <style>
        body { margin: 0; padding: 0; font-family: Arial, sans-serif; }
        /* Configuração do tamanho real da etiqueta */
        .etiqueta {
            width: 40mm;
            height: 27mm;
            padding: 1mm;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            overflow: hidden;
            border: 1px dashed #ccc; /* Só para você ver no PC, não sai na impressão */
        }
        .nome { font-size: 9px; font-weight: bold; text-align: center; line-height: 1; }
        .barcode { width: 90%; height: 12mm; }
        .barcode img { width: 100%; height: 100%; }
        .preco { font-size: 11px; font-weight: bold; }
        .info { font-size: 7px; }

        @media print {
            body { border: none; }
            .etiqueta { border: none; page-break-after: always; }
            @page { size: 40mm 27mm; margin: 0; }
        }
    </style>
</head>
<body onload="window.print()"> <div class="etiqueta">
        <div class="nome">{{ produto['nome'] }}</div>
        <div class="info">{{ produto['cor'] }} - TAM: {{ produto['tamanho_exemplo'] }}</div>
        <div class="barcode">
            <img src="data:image/png;base64,{{ barcode_img }}" alt="barcode">
        </div>
        <div class="preco">R$ {{ "%.2f"|format(produto['preco']) }}</div>
    </div>
</body>
</html>
